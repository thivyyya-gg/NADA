rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role, photo, instrument, level, bio, joinedAt, createdAt
    //
    // Collection: students
    // Fields: userId, learningStage, goals, currentStreak, totalLessons, completedMilestones, growthScore
    //
    // Collection: mentors
    // Fields: userId, specialties, experienceYears, availability, rating, isVerified
    //
    // Collection: mentor_students
    // Fields: mentorId, studentId, status, startedAt, currentPlan
    //
    // Collection: lessons
    // Fields: studentId, mentorId, instrument, date, status, type, duration, topic, notes, createdAt
    //
    // Collection: uploads
    // Fields: studentId, title, type, url, thumbnail, status, feedbackCount, instrument, createdAt, serverCreatedAt
    //
    // Collection: feedback
    // Fields: uploadId, mentorId, mentorName, text, timestamp, createdAt
    //
    // Collection: journey_entries
    // Fields: studentId, mentorId, title, description, type, date, visibleToStudent
    //
    // Collection: notifications
    // Fields: userId, type, title, body, read, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "thivyyya@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 100 &&
             data.email is string &&
             data.role in ['student', 'mentor', 'admin'];
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['studentId', 'mentorId', 'date', 'status']) &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'body', 'read', 'createdAt']);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /students/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /mentors/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /mentor_students/{relId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.mentorId);
      allow write: if isAuthenticated() && (request.auth.uid == request.resource.data.studentId || request.auth.uid == request.resource.data.mentorId || isAdmin());
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.studentId || 
        request.auth.uid == resource.data.mentorId || 
        isAdmin()
      );
      allow create: if isAuthenticated() && isValidLesson(request.resource.data) && (request.auth.uid == request.resource.data.studentId || request.auth.uid == request.resource.data.mentorId || isAdmin());
      allow update: if isAuthenticated() && isValidLesson(request.resource.data) && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.mentorId || isAdmin());
    }

    match /uploads/{uploadId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.studentId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.studentId || isAdmin());
    }

    match /feedback/{feedbackId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.mentorId;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.mentorId || isAdmin());
    }

    match /journey_entries/{entryId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.mentorId);
      allow create: if isAuthenticated() && (request.auth.uid == request.resource.data.studentId || request.auth.uid == request.resource.data.mentorId);
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.mentorId || isAdmin());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
